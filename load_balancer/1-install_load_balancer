nstalls and configures HAProxy to load balance traffic between web-01 and web-02

# Update packages and install HAProxy
apt-get update -y
apt-get install -y haproxy

# Ensure HAProxy is enabled to be managed via the init script (required for Ubuntu 16.04)
sed -i 's/ENABLED=0/ENABLED=1/g' /etc/default/haproxy

# Append the load balancer configuration to the default HAProxy config file
cat << EOF >> /etc/haproxy/haproxy.cfg

frontend www-http
    bind *:80
    mode http
    default_backend web-backend

backend web-backend
    mode http
    balance roundrobin
    server 6972-web-01 35.173.178.76:80 check
    server 6972-web-02 54.174.21.203:80 check
EOF

# Restart HAProxy to apply the new configuration
service haproxy restart
