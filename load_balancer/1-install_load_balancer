#!/usr/bin/env bash
# Installs and configures HAProxy for round-robin load balancing

# Update package lists and install HAProxy
apt-get update -y
apt-get install -y haproxy

# Enable HAProxy to be managed via init script (required for some older Ubuntu versions)
sed -i 's/ENABLED=0/ENABLED=1/g' /etc/default/haproxy

# Append the frontend and backend configurations to the HAProxy config file
cat >> /etc/haproxy/haproxy.cfg <<EOF

frontend http_front
    bind *:80
    default_backend http_back

backend http_back
    balance roundrobin
    server 6972-web-01 35.173.178.76:80 check
    server 6972-web-02 54.174.21.203:80 check
EOF

# Restart HAProxy to apply the new configuration
service haproxy restart
