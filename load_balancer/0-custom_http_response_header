#!/usr/bin/env bash
# Configures a brand new Ubuntu machine with Nginx and a custom HTTP response header

apt-get update -y
apt-get install -y nginx

# Safely fetch the hostname using the command rather than the environment variable
server_hostname=$(hostname)

# Use sed to safely inject the custom header into the default Nginx config
# This looks for the 'server_name _;' directive and adds the header right below it
sed -i "s/server_name _;/server_name _;\n\tadd_header X-Served-By $server_hostname;/g" /etc/nginx/sites-available/default

# Restart Nginx so the new configuration takes effect
service nginx restart
