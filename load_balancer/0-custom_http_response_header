#!/usr/bin/env bash
# Configures Nginx with a custom X-Served-By header

# Update and install nginx if not already present
apt-get update -y
apt-get install -y nginx

# Set the header: 'add_header X-Served-By $HOSTNAME;'
# We use 'sed' to place it inside the 'server' block (after 'listen 80 default_server;')
# This ensures it's applied to all successful responses.
CONFIG_FILE="/etc/nginx/sites-available/default"

if ! grep -q "X-Served-By" "$CONFIG_FILE"; then
    sed -i "/listen 80 default_server;/a \    add_header X-Served-By \$hostname;" "$CONFIG_FILE"
fi

# Verify configuration and restart
nginx -t && service nginx restart
