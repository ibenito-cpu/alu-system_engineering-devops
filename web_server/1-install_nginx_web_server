#!/usr/bin/env bash
# Configures an Ubuntu server with Nginx and specific content

# Update the local package index to ensure we find the latest Nginx
sudo apt-get update -y

# Install Nginx (the -y flag assumes 'yes' to prompts)
sudo apt-get install -y nginx

# Write the required string to the default index file
# This is what Nginx serves by default at the root /
echo "Holberton School for the win!" | sudo tee /var/www/html/index.html

# Start the Nginx service using the 'service' command (as systemctl is restricted)
sudo service nginx start
