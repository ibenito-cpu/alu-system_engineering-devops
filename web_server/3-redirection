#!/usr/bin/env bash
# Configures Nginx with a 301 redirect from /redirect_me

# Update and install Nginx
apt-get update -y
apt-get install -y nginx

# Create the standard index page from the previous task
echo "Holberton School for the win!" > /var/www/html/index.html

# Configure the 301 redirection
# We use 'sed' to insert the redirection line into the default config
# It looks for 'server_name _;' and adds the return 301 line right after it
REDI_URL="https://www.youtube.com/watch?v=QH2-TGUlwu4"
CONF_FILE="/etc/nginx/sites-available/default"

sed -i "/server_name _;/a \\\n\trewrite ^/redirect_me/?$ $REDI_URL permanent;" "$CONF_FILE"

# Start or restart Nginx to apply changes
service nginx restart
