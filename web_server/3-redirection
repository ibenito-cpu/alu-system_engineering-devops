#!/usr/bin/env bash
# Configures Nginx with a 301 redirect for /redirect_me

# 1. Update and Install Nginx
apt-get update -y
apt-get install -y nginx

# 2. Create the default index page
echo "Holberton School" > /var/www/html/index.html

# 3. Configure the 301 redirection
# We use sed to search for 'server_name _;' and append the redirection after it.
# This ensures the rule is inside the server { ... } block.
target_line="server_name _;"
redirect_rule="\n\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}"

sed -i "s|$target_line|$target_line$redirect_rule|" /etc/nginx/sites-available/default

# 4. Restart Nginx to apply changes (without systemctl)
service nginx restart
