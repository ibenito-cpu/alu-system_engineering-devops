#!/usr/bin/env bash
# Configures Nginx with a custom 404 error page

# Update and install Nginx
apt-get update -y
apt-get install -y nginx

# Create the custom 404 HTML file with the required string
echo "Ceci n'est pas une page" > /var/www/html/custom_404.html

# Configure Nginx to use the custom 404 page
# We use sed to insert the error_page directive inside the server block
# This specifically targets the line after 'server_name _;'
sed -i "/server_name _;/a \	error_page 404 /custom_404.html;\n\tlocation = /custom_404.html {\n\t\troot /var/www/html;\n\t\tinternal;\n\t}" /etc/nginx/sites-available/default

# Restart nginx to apply changes without using systemctl
service nginx restart
